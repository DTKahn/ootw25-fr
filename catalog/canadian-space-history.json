  },
  {
    "id": "canadian-space-history § defining-moments-in-canadian-space-histo § h21",
    "section": "defining-moments-in-canadian-space-histo",
    "tag": "h2",
    "en": "Defining Moments in Canadian Space History",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § defining-moments-in-canadian-space-histo § p1",
    "section": "defining-moments-in-canadian-space-histo",
    "tag": "p",
    "en": "Canada’s journey in space is shaped by remarkable milestones — moments when innovation, teamwork, and curiosity pushed the boundaries of exploration.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § defining-moments-in-canadian-space-histo § p2",
    "section": "defining-moments-in-canadian-space-histo",
    "tag": "p",
    "en": "Through <strong>Out of This World 25</strong>, CanHist.ca is partnering with <a href=\"https://www.esri.ca/en-ca/home\" rel=\"noopener\" target=\"_blank\"><strong>ESRI Canada</strong></a> and <a href=\"https://mcyu.mcmaster.ca/\" rel=\"noopener\" target=\"_blank\"><strong>McMaster Children and Youth University (MCYU)</strong></a> to develop interactive <strong>StoryMaps</strong> that bring these defining moments to life.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § defining-moments-in-canadian-space-histo § p3",
    "section": "defining-moments-in-canadian-space-histo",
    "tag": "p",
    "en": "Using maps, images, and multimedia storytelling, these digital experiences invite visitors to explore the people, missions, and discoveries that have shaped Canada’s role in space.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § defining-moments-in-canadian-space-histo § button1",
    "section": "defining-moments-in-canadian-space-histo",
    "tag": "button",
    "en": "EXPLORE THE STORYMAPS",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § defining-moments-in-canadian-space-histo § p4",
    "section": "defining-moments-in-canadian-space-histo",
    "tag": "p",
    "en": "<strong>Interactive StoryMaps are being developed with ESRI Canada and MCYU as part of OOTW25.</strong>",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § one-mission-in-2001-would-redefine-canad § h21",
    "section": "one-mission-in-2001-would-redefine-canad",
    "tag": "h2",
    "en": "One mission in 2001 would redefine Canada’s place in space exploration.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § chris-hadfield-and-mission-sts-100 § h21",
    "section": "chris-hadfield-and-mission-sts-100",
    "tag": "h2",
    "en": "Chris Hadfield and Mission STS-100",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § chris-hadfield-and-mission-sts-100 § p1",
    "section": "chris-hadfield-and-mission-sts-100",
    "tag": "p",
    "en": "On April 22, 2001, Canadian astronaut <strong>Chris Hadfield</strong> stepped outside the Space Shuttle <em>Endeavour</em> during <strong>Mission STS-100</strong>, becoming the first Canadian to <strong>walk in space</strong>.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § chris-hadfield-and-mission-sts-100 § p2",
    "section": "chris-hadfield-and-mission-sts-100",
    "tag": "p",
    "en": "During the mission, Hadfield helped install <strong>Canadarm2</strong> on the International Space Station — a vital piece of Canadian technology that continues to support astronauts and scientific research in orbit today.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § chris-hadfield-and-mission-sts-100 § p3",
    "section": "chris-hadfield-and-mission-sts-100",
    "tag": "p",
    "en": "This historic achievement marked a defining moment in Canada’s role in human spaceflight and inspired a new generation of Canadians to imagine their own futures in science, engineering, and exploration.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § chris-hadfield-and-mission-sts-100 § button1",
    "section": "chris-hadfield-and-mission-sts-100",
    "tag": "button",
    "en": "EXPLORE STS-100",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § in-space-exploration-technology-and-team § h21",
    "section": "in-space-exploration-technology-and-team",
    "tag": "h2",
    "en": "In space exploration, technology and teamwork make the impossible possible.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canadarm2-and-canadian-innovation § h21",
    "section": "canadarm2-and-canadian-innovation",
    "tag": "h2",
    "en": "Canadarm2 and Canadian Innovation",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canadarm2-and-canadian-innovation § p1",
    "section": "canadarm2-and-canadian-innovation",
    "tag": "p",
    "en": "Canada is internationally recognized for its leadership in <strong>space robotics</strong>.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canadarm2-and-canadian-innovation § p2",
    "section": "canadarm2-and-canadian-innovation",
    "tag": "p",
    "en": "Installed during <strong>Mission STS-100</strong>, <strong>Canadarm2</strong> plays a crucial role aboard the International Space Station. The robotic arm helps astronauts move equipment, capture visiting spacecraft, and perform complex maintenance tasks in orbit.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canadarm2-and-canadian-innovation § p3",
    "section": "canadarm2-and-canadian-innovation",
    "tag": "p",
    "en": "Along with other Canadian technologies such as <strong>Dextre</strong>, Canadarm2 demonstrates how Canadian engineering and innovation continue to support international space missions.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canadarm2-and-canadian-innovation § button1",
    "section": "canadarm2-and-canadian-innovation",
    "tag": "button",
    "en": "DISCOVER CANADARM2",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § from-robotics-to-research-canada-s-innov § h21",
    "section": "from-robotics-to-research-canada-s-innov",
    "tag": "h2",
    "en": "From robotics to research, Canada’s innovations help keep the International Space Station running.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canada-and-the-international-space-stati § h21",
    "section": "canada-and-the-international-space-stati",
    "tag": "h2",
    "en": "Canada and the International Space Station",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canada-and-the-international-space-stati § p1",
    "section": "canada-and-the-international-space-stati",
    "tag": "p",
    "en": "The <strong>International Space Station (ISS)</strong> is one of the most ambitious international collaborations in the history of science.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canada-and-the-international-space-stati § p2",
    "section": "canada-and-the-international-space-stati",
    "tag": "p",
    "en": "Canada’s contributions — particularly in robotics — have played a key role in assembling, maintaining, and operating the station. Canadian astronauts have also helped conduct scientific experiments that expand our understanding of life in space.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canada-and-the-international-space-stati § p3",
    "section": "canada-and-the-international-space-stati",
    "tag": "p",
    "en": "Through its partnership in the ISS program, Canada continues to contribute to global discovery and technological innovation.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canada-and-the-international-space-stati § button1",
    "section": "canada-and-the-international-space-stati",
    "tag": "button",
    "en": "EXPLORE THE ISS",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § exploration-begins-with-curiosity-and-cu § h21",
    "section": "exploration-begins-with-curiosity-and-cu",
    "tag": "h2",
    "en": "Exploration begins with curiosity — and curiosity begins with learning.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § explore-the-canadian-space-agency § h21",
    "section": "explore-the-canadian-space-agency",
    "tag": "h2",
    "en": "Explore the Canadian Space Agency",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § explore-the-canadian-space-agency § p1",
    "section": "explore-the-canadian-space-agency",
    "tag": "p",
    "en": "Behind every space mission are teams of engineers, scientists, and astronauts working together to push the boundaries of discovery.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § explore-the-canadian-space-agency § p2",
    "section": "explore-the-canadian-space-agency",
    "tag": "p",
    "en": "The <strong>Canadian Space Agency (CSA)</strong> leads Canada’s efforts in space science, astronaut training, and technological development. Its facilities support research, mission planning, and the preparation of future space explorers.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § explore-the-canadian-space-agency § p3",
    "section": "explore-the-canadian-space-agency",
    "tag": "p",
    "en": "Take a closer look at the place where many of Canada’s space missions begin.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § explore-the-canadian-space-agency § button1",
    "section": "explore-the-canadian-space-agency",
    "tag": "button",
    "en": "TAKE THE VIRTUAL TOUR",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § canada-s-story-in-space-continues-to-ins § h21",
    "section": "canada-s-story-in-space-continues-to-ins",
    "tag": "h2",
    "en": "Canada’s story in space continues to inspire the explorers of tomorrow.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § a-new-chapter-in-canada-s-story-in-space § h21",
    "section": "a-new-chapter-in-canada-s-story-in-space",
    "tag": "h2",
    "en": "A New Chapter in Canada’s Story in Space",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § a-new-chapter-in-canada-s-story-in-space § p1",
    "section": "a-new-chapter-in-canada-s-story-in-space",
    "tag": "p",
    "en": "Canada’s journey in space is far from over.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § a-new-chapter-in-canada-s-story-in-space § p2",
    "section": "a-new-chapter-in-canada-s-story-in-space",
    "tag": "p",
    "en": "The achievements of astronauts like <strong>Chris Hadfield</strong>, together with Canada’s leadership in space robotics and international collaboration, have helped shape a remarkable national story of discovery.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § a-new-chapter-in-canada-s-story-in-space § p3",
    "section": "a-new-chapter-in-canada-s-story-in-space",
    "tag": "p",
    "en": "In April 2026, Canadian astronaut <strong>Jeremy Hansen</strong> journeyed around the Moon aboard <strong>Artemis II</strong>, marking a new milestone in that story and reminding Canadians — especially young learners — that exploration continues to open new possibilities for the future.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "canadian-space-history § a-new-chapter-in-canada-s-story-in-space § button1",
    "section": "a-new-chapter-in-canada-s-story-in-space",
    "tag": "button",
    "en": "EXPLORE THE ARTEMIS II MISSION",
    "fr": "",
    "status": "pending"
  },
  {
