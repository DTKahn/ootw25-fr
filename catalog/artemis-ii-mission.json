  {
    "id": "artemis-ii-mission § canada-s-historic-giant-leap-carried-us- § h21",
    "section": "canada-s-historic-giant-leap-carried-us-",
    "tag": "h2",
    "en": "Canada’s historic giant leap carried us around the Moon.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § canada-s-mission-to-the-moon § h21",
    "section": "canada-s-mission-to-the-moon",
    "tag": "h2",
    "en": "Canada’s Mission to the Moon",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § canada-s-mission-to-the-moon § p1",
    "section": "canada-s-mission-to-the-moon",
    "tag": "p",
    "en": "Artemis II was the first crewed mission around the Moon since 1972 and the first crewed flight of NASA’s Orion spacecraft and Space Launch System. Launched on April 1, 2026, the mission lasted nearly 10 days and marked a major milestone in the return of humans to deep space.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § canada-s-mission-to-the-moon § p2",
    "section": "canada-s-mission-to-the-moon",
    "tag": "p",
    "en": "For Canada, Artemis II was historic.<strong> Jeremy Hansen became the first Canadian to take part in a lunar mission</strong>, marking a defining moment in Canada’s role in human space exploration.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § canada-s-mission-to-the-moon § p3",
    "section": "canada-s-mission-to-the-moon",
    "tag": "p",
    "en": "Through Out of This World 25, Artemis II connects Chris Hadfield’s 2001 mission with a new chapter in Canada’s journey in space. That connection remains central to OOTW25’s vision of linking past achievements with future possibilities.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § a-remarkable-moment-from-a-historic-miss § h21",
    "section": "a-remarkable-moment-from-a-historic-miss",
    "tag": "h2",
    "en": "A remarkable moment from a historic mission.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § jeremy-hansen-from-orion § h21",
    "section": "jeremy-hansen-from-orion",
    "tag": "h2",
    "en": "Jeremy Hansen from Orion",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § jeremy-hansen-from-orion § p1",
    "section": "jeremy-hansen-from-orion",
    "tag": "p",
    "en": "During Artemis II’s journey around the Moon, Canadian astronaut<strong> Jeremy Hansen </strong>shared a message from Orion in French — <strong>becoming the first astronaut in history to speak French while en route to the Moon</strong>.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § jeremy-hansen-from-orion § p2",
    "section": "jeremy-hansen-from-orion",
    "tag": "p",
    "en": "Watch his message as part of this historic mission and reflect on what it means for Canada’s continuing story in space.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § jeremy-hansen-from-orion § p3",
    "section": "jeremy-hansen-from-orion",
    "tag": "p",
    "en": "<em>Source: Canadian Space Agency</em>",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § the-path-from-earth-orbit-to-deep-space- § h21",
    "section": "the-path-from-earth-orbit-to-deep-space-",
    "tag": "h2",
    "en": "The path from Earth orbit to deep space is shaped by courage, preparation, and teamwork.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § why-artemis-ii-matters-for-canada § h21",
    "section": "why-artemis-ii-matters-for-canada",
    "tag": "h2",
    "en": "Why Artemis II Matters for Canada",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § why-artemis-ii-matters-for-canada § p1",
    "section": "why-artemis-ii-matters-for-canada",
    "tag": "p",
    "en": "Artemis II is more than a Moon mission. It marks a major step in Canada’s continuing role in global space exploration.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § why-artemis-ii-matters-for-canada § p2",
    "section": "why-artemis-ii-matters-for-canada",
    "tag": "p",
    "en": "Because of <strong>Canada’s contribution</strong> to the Gateway lunar program through <strong>Canadarm3</strong>, Canada secured astronaut flights connected to the Artemis program, including <strong>Jeremy Hansen’s seat on Artemis II. </strong>",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § why-artemis-ii-matters-for-canada § p3",
    "section": "why-artemis-ii-matters-for-canada",
    "tag": "p",
    "en": "With Artemis II, Canada became the second country to send a human beyond low Earth orbit and the first non-American nation to take part in a lunar mission. The mission also helped test the systems, operations, and teamwork needed for future exploration of the Moon and beyond.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § why-artemis-ii-matters-for-canada § button1",
    "section": "why-artemis-ii-matters-for-canada",
    "tag": "button",
    "en": "EXPLORE THE CSA MISSION PAGE",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § four-astronauts-traveled-farther-from-ea § h21",
    "section": "four-astronauts-traveled-farther-from-ea",
    "tag": "h2",
    "en": "Four astronauts traveled farther from Earth than any crew in more than half a century.",
    "fr": "",
    "status": "pending"
  },
  {
