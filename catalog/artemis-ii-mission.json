  {
    "id": "artemis-ii-mission § before-astronauts-can-journey-around-the § h21",
    "section": "before-astronauts-can-journey-around-the",
    "tag": "h2",
    "en": "Before astronauts can journey around the Moon, every system must be tested for deep space.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § orion-sls-and-the-mission § h21",
    "section": "orion-sls-and-the-mission",
    "tag": "h2",
    "en": "Orion, SLS, and the Mission",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § orion-sls-and-the-mission § p1",
    "section": "orion-sls-and-the-mission",
    "tag": "p",
    "en": "Artemis II was the first crewed test flight of <strong>Orion</strong> launched on NASA’s <strong>Space Launch System</strong> (SLS) rocket. The mission carried four astronauts into deep space, around the Moon, and safely back to Earth.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § orion-sls-and-the-mission § p2",
    "section": "orion-sls-and-the-mission",
    "tag": "p",
    "en": "The flight was designed to test the spacecraft, life-support systems, crew operations, and deep-space procedures needed for future lunar exploration. As a crewed test mission, Artemis II marked an essential step toward the next phase of human exploration beyond Earth orbit.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § orion-sls-and-the-mission § button1",
    "section": "orion-sls-and-the-mission",
    "tag": "button",
    "en": "LEARN ABOUT ORION &amp; SLS",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § canada-s-journey-to-the-moon-is-also-a-s § h21",
    "section": "canada-s-journey-to-the-moon-is-also-a-s",
    "tag": "h2",
    "en": "Canada’s journey to the Moon is also a story of preparation, partnership, and possibility.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § jeremy-hansen-s-historic-role § h21",
    "section": "jeremy-hansen-s-historic-role",
    "tag": "h2",
    "en": "Jeremy Hansen’s Historic Role",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § jeremy-hansen-s-historic-role § p1",
    "section": "jeremy-hansen-s-historic-role",
    "tag": "p",
    "en": "CSA astronaut <strong>Jeremy Hansen</strong> made history as the first Canadian to fly around the Moon. His role on Artemis II marked a major milestone not only for Canada’s astronaut program, but also for the next generation of Canadians watching the mission unfold.",
    "fr": "",
    "status": "pending"
  },
  {
    "id": "artemis-ii-mission § jeremy-hansen-s-historic-role § p2",
    "section": "jeremy-hansen-s-historic-role",
    "tag": "p",
    "en": "For OOTW25, Jeremy Hansen’s participation in Artemis II connects Canada’s past achievements in space to the future of exploration — showing how one generation of milestones can inspire the next.",
    "fr": "",
    "status": "pending"
  },
